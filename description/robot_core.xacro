<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot">

<xacro:include filename="inertial_macros.xacro" />

<material name="blue">
    <color rgba="0.2 0.2 1 1"/>
</material>
<material name="white">
    <color rgba="1 1 1 1"/>
</material>

<link name="base_link">
</link>

<joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
</joint>

<link name="base_footprint">
</link>

<joint name="chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
</joint>

<link name="chassis">
    <visual>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry>
            <box size="0.3 0.3 0.15"/>
        </geometry>
        <material name="white"/>
    </visual>
    <collision>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry>
            <box size="0.3 0.3 0.15"/>
        </geometry>
    </collision>
    <xacro:inertial_box mass="20" x="0.3" y="0.3" z="0.15">
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
    </xacro:inertial_box>
</link>

<gazebo reference="chassis">
    <material>Gazebo/White</material>
</gazebo>

<!-- front_left_wheel_joint -->

<joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.075 0.17 0.05" rpy="-${pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
</joint>

<link name="front_left_wheel">
    <visual>
        <geometry>
            <cylinder length="0.04" radius="0.05" />
        </geometry>
        <material name="blue"/>
    </visual>
    <collision>
        <geometry>
            <cylinder length="0.04" radius="0.05" />
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="2" length="0.04" radius="0.05">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
</link>

<!-- back_left_wheel_joint -->

<joint name="back_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_left_wheel"/>
    <origin xyz="-0.075 0.17 0.05" rpy="-${pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
</joint>

<link name="back_left_wheel">
    <visual>
        <geometry>
            <cylinder length="0.04" radius="0.05" />
        </geometry>
        <material name="blue"/>
    </visual>
    <collision>
        <geometry>
            <cylinder length="0.04" radius="0.05" />
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="2" length="0.04" radius="0.05">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
</link>

<!-- front_right_wheel_joint -->

<joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.075 -0.17 0.05" rpy="${pi/2} 0 0"/>
    <axis xyz="0 0 -1"/>
</joint>

<link name="front_right_wheel">
    <visual>
        <geometry>
            <cylinder length="0.04" radius="0.05" />
        </geometry>
        <material name="blue"/>
    </visual>
    <collision>
        <geometry>
            <cylinder length="0.04" radius="0.05" />
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="2" length="0.04" radius="0.05">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
</link>

<!-- back_right_wheel_joint -->

<joint name="back_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_right_wheel"/>
    <origin xyz="-0.075 -0.17 0.05" rpy="${pi/2} 0 0"/>
    <axis xyz="0 0 -1"/>
</joint>

<link name="back_right_wheel">
    <visual>
        <geometry>
            <cylinder length="0.04" radius="0.05" />
        </geometry>
        <material name="blue"/>
    </visual>
    <collision>
        <geometry>
            <cylinder length="0.04" radius="0.05" />
        </geometry>
    </collision>
    <xacro:inertial_cylinder mass="2" length="0.04" radius="0.05">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
</link>

<gazebo reference="front_left_wheel">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    </gazebo>

<gazebo reference="front_right_wheel">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
</gazebo>

<gazebo reference="back_left_wheel">
    <mu1>0.2</mu1>      
    <mu2>0.2</mu2>     
</gazebo>

<gazebo reference="back_right_wheel">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
</gazebo>

<!-- ARM BASE -->
<joint name="arm_base1_joint" type="fixed">
    <parent link="chassis"/>
    <child link="arm_base1"/>
    <origin xyz="0.175 0 0" rpy="0 0 0"/> 
</joint>

<link name="arm_base1">
    <visual>
        <origin xyz="0 0 0.15" rpy="0 0 0"/>
        <geometry>
            <box size="0.05 0.05 0.3"/>
        </geometry>
        <material name="white"/>
    </visual>
    <collision>
        <origin xyz="0 0 0.15" rpy="0 0 0"/>
        <geometry>
            <box size="0.05 0.05 0.3"/>
        </geometry>
    </collision>
    <xacro:inertial_box mass="0.5" x="0.05" y="0.05" z="0.3">
        <origin xyz="0 0 0.15" rpy="0 0 0"/>
    </xacro:inertial_box>
</link>

<joint name="arm_base2_joint" type="prismatic">
    <parent link="arm_base1"/>
    <child link="arm_base2"/>
    <origin xyz="0.05 0 0.025" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="0.2" effort="1000" velocity="1.0"/>
</joint>

<link name="arm_base2">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
            <box size="0.05 0.54 0.05"/>
        </geometry>
        <material name="white"/>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
            <box size="0.05 0.54 0.05"/>
        </geometry>
    </collision>
    <xacro:inertial_box mass="0.2" x="0.05" y="0.54" z="0.05">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_box>
</link>

<!-- ARM L -->

<joint name="arm_slide_joint_L" type="prismatic">
    <parent link="arm_base2"/>
    <child link="arm_link_L"/>
    <origin xyz="0 -0.26375 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0.26375" effort="1000" velocity="1.0"/>
</joint>

<link name="arm_link_L">
    <visual>
        <origin xyz="0.075 0 0" rpy="0 0 0"/>
        <geometry>
            <box size="0.15 0.0125 0.05"/>
        </geometry>
        <material name="white"/>
    </visual>
    <collision>
        <origin xyz="0.075 0 0" rpy="0 0 0"/>
        <geometry>
            <box size="0.15 0.0125 0.05"/>
        </geometry>
    </collision>
    <xacro:inertial_box mass="0.1" x="0.15" y="0.0125" z="0.05">
        <origin xyz="0.075 0 0" rpy="0 0 0"/>
    </xacro:inertial_box>
   
</link>

 <gazebo reference="arm_link_L">
        <mu1>100.0</mu1>
        <mu2>100.0</mu2>
        <kp>1000000.0</kp>
        <kd>1.0</kd>
        <material>Gazebo/White</material>
</gazebo>

<!-- ARM R -->

<joint name="arm_slide_joint_R" type="prismatic">
    <parent link="arm_base2"/>
    <child link="arm_link_R"/>
    <origin xyz="0 0.26375 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.26375" upper="0" effort="1000" velocity="1.0"/>
</joint>

<link name="arm_link_R">
    <visual>
        <origin xyz="0.075 0 0" rpy="0 0 0"/>
        <geometry>
            <box size="0.15 0.0125 0.05"/>
        </geometry>
        <material name="white"/>
    </visual>
    <collision>
        <origin xyz="0.075 0 0" rpy="0 0 0"/>
        <geometry>
            <box size="0.15 0.0125 0.05"/>
        </geometry>
    </collision>
    <xacro:inertial_box mass="0.1" x="0.15" y="0.0125" z="0.05">
        <origin xyz="0.075 0 0" rpy="0 0 0"/>
    </xacro:inertial_box>
   
</link>

<gazebo reference="arm_link_R">
        <mu1>100.0</mu1>
        <mu2>100.0</mu2>
        <kp>1000000.0</kp>
        <kd>1.0</kd>
        <material>Gazebo/White</material>
</gazebo>



</robot>